rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Examinations collection
    match /examinations/{examinationId} {
      function isValidExamination(data) {
        return data.patientId is string && data.patientId.size() > 0 &&
               data.patientName is string &&
               data.date is string && // date-time format
               data.prediction in ["Normal", "Tuberculosis (TBC)", "Pneumonia"] &&
               data.confidence is number &&
               data.doctorUid == request.auth.uid &&
               (data.imageUrl == null || data.imageUrl is string) &&
               (data.heatmapUrl == null || data.heatmapUrl is string);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidExamination(incoming()) && isValidId(examinationId);
      allow update: if isSignedIn() && isValidExamination(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'patientName'])
      );
      allow delete: if false; // Medical records shouldn't be deleted easily
    }
  }
}
